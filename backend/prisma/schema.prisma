generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Client {
  id           String        @id @default(cuid())
  firstName    String
  lastName     String
  phone        String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  financials   Financial[]

  @@map("clients")
}

model Service {
  id           String        @id @default(cuid())
  name         String
  price        Float
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]

  @@map("services")
}

model PaymentMethod {
  id           String        @id @default(cuid())
  name         String
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  financials   Financial[]

  @@map("payment_methods")
}

model Appointment {
  id              String            @id @default(cuid())
  clientId        String
  serviceId       String
  paymentMethodId String?
  date            DateTime
  status          AppointmentStatus @default(SCHEDULED)
  notes           String?
  value           Float
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  client          Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service         Service           @relation(fields: [serviceId], references: [id])
  paymentMethod   PaymentMethod?    @relation(fields: [paymentMethodId], references: [id])
  financial       Financial?

  @@map("appointments")
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Financial {
  id              String        @id @default(cuid())
  type            FinancialType
  clientId        String?
  appointmentId   String?       @unique
  paymentMethodId String?
  description     String
  value           Float
  date            DateTime
  category        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  client          Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  appointment     Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  @@map("financials")
}

enum FinancialType {
  INCOME
  EXPENSE
}

model Inventory {
  id           String   @id @default(cuid())
  name         String
  value        Float
  purchaseDate DateTime
  notes        String?
  category     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("inventory")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}
